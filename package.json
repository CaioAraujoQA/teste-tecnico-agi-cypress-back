{
  "name": "automacao-testes-back-end",
  "version": "1.0.0",
  "scripts": {
    "cy:run": "cypress run",
    "report:merge": "mochawesome-merge cypress/reports/*.json -o cypress/reports/report.json",
    "report:generate": "marge cypress/reports/report.json -f report -o cypress/reports",
    "report": "npm run report:merge && npm run report:generate",
    "test": "npm run cy:run && npm run report"
  },
  "devDependencies": {
    "cypress": "^13.17.0",
    "cypress-mochawesome-reporter": "^3.2.0",
    "cypress-terminal-report": "^6.1.0",
    "cypress-xpath": "^2.0.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.4.1",
    "mochawesome-report-generator": "^6.3.2",
    "rimraf": "^3.0.2",
    "sonarqube-scanner": "^4.0.1"
  }
}